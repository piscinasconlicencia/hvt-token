  <!-- Fade radial en bordes del mapa -->
  <radialGradient id="fade" cx="50%" cy="50%" r="50%">
    <stop offset="55%" stop-color="#080808" stop-opacity="0"/>
    <stop offset="88%" stop-color="#080808" stop-opacity="0.7"/>
    <stop offset="100%" stop-color="#080808" stop-opacity="1"/>
  </radialGradient>
  <rect width="520" height="520" fill="url(#fade)"/>

  <!-- Anillo exterior dorado -->
  <circle cx="260" cy="260" r="234" fill="none" stroke="#C8A84B" stroke-width="2.5"/>
  <!-- Anillo con segmentos tipo código -->
  <circle cx="260" cy="260" r="226" fill="none" stroke="#3A3020" stroke-width="6"/>
  <circle cx="260" cy="260" r="226" fill="none" stroke="#C8A84B" stroke-width="1.5" stroke-dasharray="8 4 2 4 14 4 2 4 8 4 20 4"/>
  <!-- Anillo interior sutil -->
  <circle cx="260" cy="260" r="215" fill="none" stroke="#333328" stroke-width="0.8"/>

  <!-- Rombos cardinales dorados -->
  <polygon points="260,22 265,32 260,42 255,32" fill="#C8A84B"/>
  <polygon points="260,478 265,488 260,498 255,488" fill="#C8A84B"/>
  <polygon points="22,260 32,255 42,260 32,265" fill="#C8A84B"/>
  <polygon points="478,260 488,255 498,260 488,265" fill="#C8A84B"/>
  <!-- Marcas de precisión -->
  <g stroke="#C8A84B" stroke-width="1.5" opacity="0.6">
    <line x1="260" y1="28" x2="260" y2="44"/>
    <line x1="260" y1="476" x2="260" y2="492"/>
    <line x1="28" y1="260" x2="44" y2="260"/>
    <line x1="476" y1="260" x2="492" y2="260"/>
  </g>
