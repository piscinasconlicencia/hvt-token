  <polygon points="424,96 420,100 424,108" fill="#8A6E2A" opacity="0.7"/>
  <polygon points="96,424 104,420 100,412" fill="#8A6E2A" opacity="0.7"/>
  <polygon points="424,424 420,420 424,412" fill="#8A6E2A" opacity="0.7"/>

  <!-- Texto superior HUMAN VALUE TOKEN -->
  <text x="260" y="104" text-anchor="middle" font-family="Georgia, serif" font-size="15" font-weight="400" fill="#C8A84B" letter-spacing="5.5">HUMAN VALUE TOKEN</text>
  <line x1="82" y1="104" x2="120" y2="104" stroke="#8A6E2A" stroke-width="0.8"/>
  <line x1="400" y1="104" x2="438" y2="104" stroke="#8A6E2A" stroke-width="0.8"/>

  <!-- Símbolo ℍ grande y centrado -->
  <text x="260" y="288" text-anchor="middle" dominant-baseline="central" font-family="Georgia, serif" font-size="210" font-weight="700" fill="#C8A84B">ℍ</text>

  <!-- Líneas decorativas bajo ℍ -->
  <line x1="175" y1="368" x2="345" y2="368" stroke="#8A6E2A" stroke-width="0.8"/>
  <line x1="195" y1="374" x2="325" y2="374" stroke="#3A3020" stroke-width="0.5"/>

  <!-- HVT inferior -->
